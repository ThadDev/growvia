npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

