# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
# assets
/public/*.jpg
/public/*.jpeg
/public/*.png
/public/*.webp
/public/*.svg
!/public/logo.png
!/public/hero.png
!/public/hero.webp
